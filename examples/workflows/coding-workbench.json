{
  "id": "default-planner-led-runtime",
  "version": "0.3",
  "name": "Planner-led Agent Workflow",
  "description": "Planner decides. Code Worker proposes changes by order. Tester returns evidence. Runtime graph details stay hidden.",
  "max_steps": 18,
  "max_agent_calls": 18,
  "max_tool_calls": 0,
  "token_budget": 80000,
  "agents": [
    {
      "id": "planner_contract",
      "name": "Planner Agent",
      "role": "Planner Agent",
      "goal": "Negotiate the RunContract with the human-facing request.",
      "instructions": "Return strict JSON for the requested artifact. Do not include full transcripts. Use only structured runtime inputs.",
      "tools": [],
      "output_key": "run_contract",
      "artifact_type": "run_contract",
      "permissions": {
        "read_files": true,
        "edit_files": false,
        "run_commands": false,
        "use_network": false,
        "requires_approval": false
      },
      "context": {
        "input_keys": [],
        "summary_keys": [],
        "max_items_per_key": 12,
        "max_chars_per_value": 3500,
        "include_all_state": false,
        "include_event_history": false,
        "include_full_outputs": false
      }
    },
    {
      "id": "planner_order",
      "name": "Planner Agent",
      "role": "Planner Agent",
      "goal": "Produce the next executable order for the Code Worker.",
      "instructions": "Return strict JSON for the requested artifact. Do not include full transcripts. Use only structured runtime inputs.",
      "tools": [],
      "output_key": "planner_order",
      "artifact_type": "planner_order",
      "permissions": {
        "read_files": true,
        "edit_files": false,
        "run_commands": false,
        "use_network": false,
        "requires_approval": false
      },
      "context": {
        "input_keys": ["run_contract", "round_summary", "execution_result", "test_result"],
        "summary_keys": ["round_summary"],
        "max_items_per_key": 12,
        "max_chars_per_value": 3500,
        "include_all_state": false,
        "include_event_history": false,
        "include_full_outputs": false
      }
    },
    {
      "id": "executor",
      "name": "Code Worker Agent",
      "role": "Code Worker Agent",
      "goal": "Follow PlannerOrder and return only execution facts.",
      "instructions": "Return strict JSON for the requested artifact. Do not include full transcripts. Use only structured runtime inputs.",
      "tools": [],
      "output_key": "execution_result",
      "artifact_type": "execution_result",
      "permissions": {
        "read_files": true,
        "edit_files": true,
        "run_commands": false,
        "use_network": false,
        "requires_approval": true
      },
      "context": {
        "input_keys": ["run_contract", "planner_order"],
        "summary_keys": ["run_contract", "planner_order"],
        "max_items_per_key": 12,
        "max_chars_per_value": 3500,
        "include_all_state": false,
        "include_event_history": false,
        "include_full_outputs": false
      }
    },
    {
      "id": "tester",
      "name": "Tester Agent",
      "role": "Tester Agent",
      "goal": "Review execution evidence and return a TestResult.",
      "instructions": "Return strict JSON for the requested artifact. Do not include full transcripts. Use only structured runtime inputs.",
      "tools": [],
      "output_key": "test_result",
      "artifact_type": "test_result",
      "permissions": {
        "read_files": true,
        "edit_files": false,
        "run_commands": false,
        "use_network": false,
        "requires_approval": false
      },
      "context": {
        "input_keys": ["planner_order", "execution_result"],
        "summary_keys": ["planner_order", "execution_result"],
        "max_items_per_key": 12,
        "max_chars_per_value": 3500,
        "include_all_state": false,
        "include_event_history": false,
        "include_full_outputs": false
      }
    },
    {
      "id": "planner_decision",
      "name": "Planner Agent",
      "role": "Planner Agent",
      "goal": "Decide whether to finish, continue, ask the human, or stop.",
      "instructions": "Return strict JSON for the requested artifact. Do not include full transcripts. Use only structured runtime inputs.",
      "tools": [],
      "output_key": "planner_decision",
      "artifact_type": "planner_decision",
      "permissions": {
        "read_files": true,
        "edit_files": false,
        "run_commands": false,
        "use_network": false,
        "requires_approval": false
      },
      "context": {
        "input_keys": ["run_contract", "execution_result", "test_result", "round_summary"],
        "summary_keys": ["execution_result", "test_result", "round_summary"],
        "max_items_per_key": 12,
        "max_chars_per_value": 3500,
        "include_all_state": false,
        "include_event_history": false,
        "include_full_outputs": false
      }
    },
    {
      "id": "round_summarizer",
      "name": "Planner Agent",
      "role": "Planner Agent",
      "goal": "Compress this round into a compact carry-forward summary.",
      "instructions": "Return strict JSON for the requested artifact. Do not include full transcripts. Use only structured runtime inputs.",
      "tools": [],
      "output_key": "round_summary",
      "artifact_type": "round_summary",
      "permissions": {
        "read_files": true,
        "edit_files": false,
        "run_commands": false,
        "use_network": false,
        "requires_approval": false
      },
      "context": {
        "input_keys": ["planner_order", "execution_result", "test_result", "planner_decision"],
        "summary_keys": ["planner_order", "execution_result", "test_result", "planner_decision"],
        "max_items_per_key": 12,
        "max_chars_per_value": 3500,
        "include_all_state": false,
        "include_event_history": false,
        "include_full_outputs": false
      }
    }
  ],
  "nodes": [
    { "id": "start", "type": "start" },
    { "id": "run_contract", "type": "agent", "agent_id": "planner_contract", "output_key": "run_contract" },
    { "id": "planner_order", "type": "agent", "agent_id": "planner_order", "output_key": "planner_order" },
    { "id": "execute", "type": "agent", "agent_id": "executor", "output_key": "execution_result" },
    { "id": "test", "type": "agent", "agent_id": "tester", "output_key": "test_result" },
    { "id": "planner_decision", "type": "agent", "agent_id": "planner_decision", "output_key": "planner_decision" },
    { "id": "round_summary", "type": "agent", "agent_id": "round_summarizer", "output_key": "round_summary" },
    {
      "id": "planner_loop",
      "type": "loop",
      "loop_mode": "retry_until",
      "condition": "planner_decision.next_action == 'finish' or planner_decision.next_action == 'stop' or planner_decision.next_action == 'ask_human'",
      "max_iterations": 3,
      "output_key": "planner_loop"
    },
    { "id": "finish", "type": "end" }
  ],
  "edges": [
    { "from": "start", "to": "run_contract" },
    { "from": "run_contract", "to": "planner_order" },
    { "from": "planner_order", "to": "execute" },
    { "from": "execute", "to": "test" },
    { "from": "test", "to": "planner_decision" },
    { "from": "planner_decision", "to": "round_summary" },
    { "from": "round_summary", "to": "planner_loop" },
    {
      "from": "planner_loop",
      "to": "planner_order",
      "when": "planner_loop.should_continue == True",
      "max_traversals": 3
    },
    { "from": "planner_loop", "to": "finish", "when": "planner_loop.should_continue == False" }
  ],
  "stop_conditions": [
    "planner_decision.next_action == finish",
    "planner_decision.next_action == ask_human",
    "planner_decision.next_action == stop",
    "max_auto_rounds reached",
    "token budget exceeded"
  ]
}
